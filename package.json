{
  "name": "markdown-runner",
  "displayName": "Markdown Code Block Runner",
  "description": "Enables the seamless execution of code blocks in any language within Markdown files in VS Code",
  "publisher": "renathossain",
  "icon": "Icon.png",
  "version": "2.8.0",
  "engines": {
    "vscode": "^1.116.0"
  },
  "categories": [
    "Other"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/renathossain/vscode-markdown-runner.git"
  },
  "activationEvents": [
    "onLanguage:markdown",
    "onLanguage:quarto"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "Markdown Code Block Runner",
      "properties": {
        "markdownRunner.compilerConfiguration": {
          "type": "object",
          "description": "Configure language compilers by specifying for each `Language (Code Block Tag)`, the following value: `[Language Name, File Extension, Compiler Command/Path]`. Only non-compiled languages can be added. Reset settings using the ↻ icons that appear when hovering on each setting.",
          "additionalProperties": {
            "type": "string"
          },
          "default": {
            "python": "[\"Python\", \"py\", \"python\"]",
            "c": "[\"C\", \"c\", \"gcc\"]",
            "java": "[\"Java\", \"java\", \"javac\"]",
            "cpp": "[\"C++\", \"cpp\", \"g++\"]",
            "rust": "[\"Rust\", \"rs\", \"rustc\"]",
            "typescript": "[\"TypeScript\", \"ts\", \"tsc --ignoreConfig\"]",
            "php": "[\"PHP\", \"php\", \"php\"]",
            "perl": "[\"Perl\", \"pl\", \"perl\"]",
            "r": "[\"R\", \"r\", \"Rscript\"]",
            "dart": "[\"Dart\", \"dart\", \"dart\"]",
            "groovy": "[\"Groovy\", \"groovy\", \"groovy\"]",
            "go": "[\"Go\", \"go\", \"go run\"]",
            "haskell": "[\"Haskell\", \"hs\", \"stack runghc\"]",
            "julia": "[\"Julia\", \"jl\", \"julia\"]",
            "lua": "[\"Lua\", \"lua\", \"lua\"]",
            "ruby": "[\"Ruby\", \"rb\", \"ruby\"]",
            "javascript": "[\"JavaScript\", \"js\", \"node\"]",
            "bash": "[\"Bash\", \"sh\", \"bash\"]",
            "powershell": "[\"Powershell\", \"ps1\", \"powershell\"]"
          }
        },
        "markdownRunner.pythonPath": {
          "type": "boolean",
          "description": "Enable to add the Markdown file's parent directory to Python's `sys.path`, allowing you to import modules from that directory.",
          "default": true
        },
        "markdownRunner.defaultCodes": {
          "type": "object",
          "description": "Prepend or wrap your code blocks with default code to improve readability, by specifying for each `language (Code Block Tag)`, either the string to be prepended or the `-I@` (insert at) flag followed by whitespace and a string containing the `@` symbol where you want to insert the code. Examples:\nItem: `bash`, Value: `var=123\\n`\nItem: `cpp`, Value: `-I@ #include <bits/stdc++.h>\\nusing namespace std;\\nint main(){\\n@}\\n`",
          "additionalProperties": {
            "type": "string"
          },
          "default": {}
        },
        "markdownRunner.activateOnQuarto": {
          "type": "boolean",
          "description": "Enable to activate the extension on Quarto (.qmd) files.",
          "default": true
        },
        "markdownRunner.outputEncoding": {
          "type": "string",
          "enum": [
            "utf8",
            "utf16le",
            "latin1",
            "ascii",
            "base64",
            "hex",
            "gbk"
          ],
          "default": "utf8",
          "description": "Encoding used to decode `Run on Markdown` process output. Supports `utf8`, `utf16le`, `latin1`, `ascii`, `base64`, `hex`, and `gbk`. Change this if non-ASCII characters appear corrupted (e.g. change to `gbk` on some Windows systems)."
        }
      }
    },
    "languages": [
      {
        "id": "quarto",
        "extensions": [
          ".qmd"
        ]
      }
    ]
  },
  "scripts": {
    "build": "vsce package",
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@eslint/markdown": "^8.0.1",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.8.0",
    "@types/vscode": "^1.116.0",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.1",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.6.0",
    "mocha": "^11.3.0",
    "ovsx": "^0.10.12",
    "prettier": "^3.8.3",
    "ts-loader": "^9.5.7",
    "tsx": "^4.22.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "webpack": "^5.106.2",
    "webpack-cli": "^7.0.2"
  },
  "dependencies": {
    "iconv-lite": "^0.7.2",
    "semaphore-async-await": "^1.5.1",
    "tree-kill": "^1.2.2"
  }
}
